# Normalize line endings to LF for files that cargo regenerates / git
# normalizes, so `git add` stops warning about CRLF conversion on Windows
# (where core.autocrlf=true converts text files to CRLF on checkout).
Cargo.lock text eol=lf
.gitattributes text eol=lf
Cargo.toml text eol=lf
*.rs text eol=lf
